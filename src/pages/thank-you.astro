---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You | DialedPPC"
  description="Your whitepaper is ready to download."
>

<section class="thankyou-section">
  <div class="thankyou-inner">
    <div class="thankyou-status">
      <span class="status-dot"></span>
      <span class="status-text">Download Ready</span>
    </div>

    <h1>You're in.</h1>
    <p class="thankyou-sub">
      Your copy of the whitepaper is ready. Click below to download it now.
    </p>

    <a href="/DialedPPC_Whitepaper.pdf" download class="btn-primary btn-download">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 2v10M9 12l-3.5-3.5M9 12l3.5-3.5M3 14h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Download the Whitepaper (PDF)
    </a>

    <div class="thankyou-divider"></div>

    <div class="next-step">
      <div class="next-step-label">Go deeper</div>
      <p>
        Want a structured, step-by-step system for auditing and rebuilding your Amazon PPC campaigns?
      </p>
      <a href="https://dialedadmin.gumroad.com/l/egeft" target="_blank" rel="noopener noreferrer" class="guide-link">
        Get the full guide — $19 on Gumroad <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .thankyou-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
  }

  .thankyou-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .thankyou-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-green);
    margin-bottom: 2rem;
  }

  .thankyou-status .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 8px var(--accent-green);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent-green); }
    50% { opacity: 0.6; box-shadow: 0 0 4px var(--accent-green); }
  }

  .thankyou-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  .thankyou-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .btn-download {
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    padding: 1.1rem 2.5rem;
  }

  .thankyou-divider {
    width: 60px;
    height: 1px;
    background: var(--border-subtle);
    margin: 3rem auto;
  }

  .next-step {
    text-align: center;
  }

  .next-step-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .next-step p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .guide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent-amber);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: gap 0.3s;
  }

  .guide-link:hover {
    gap: 0.8rem;
  }

  .guide-link .arrow {
    transition: transform 0.3s;
    font-size: 1rem;
  }

  .guide-link:hover .arrow {
    transform: translateX(3px);
  }

  @media (max-width: 600px) {
    .thankyou-section {
      padding: 6rem 1.25rem 3rem;
    }
  }
</style>
